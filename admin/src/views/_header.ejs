<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Trainwise Admin' %></title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous">
</head>
<body>
<div class="layout">

  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <div class="brand-title">Train<span>wise</span></div>
      <div class="brand-sub">Back-office</div>
    </div>
    <nav class="sidebar-nav">
      <span class="nav-section-label">Menu</span>
      <a href="/dashboard" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
        <i class="fa-solid fa-chart-pie"></i> Dashboard
      </a>
      <a href="/users" class="nav-item <%= page === 'users' ? 'active' : '' %>">
        <i class="fa-solid fa-users"></i> Utilisateurs
      </a>
      <a href="/coaches" class="nav-item <%= page === 'coaches' ? 'active' : '' %>">
        <i class="fa-solid fa-whistle"></i> Coaches
      </a>
      <a href="/runs" class="nav-item <%= page === 'runs' ? 'active' : '' %>">
        <i class="fa-solid fa-route"></i> Sorties
      </a>
      <span class="nav-section-label" style="margin-top:8px;">Analytique</span>
      <a href="/revenue" class="nav-item <%= page === 'revenue' ? 'active' : '' %>">
        <i class="fa-solid fa-euro-sign"></i> Revenus
      </a>
      <a href="/ai" class="nav-item <%= page === 'ai' ? 'active' : '' %>">
        <i class="fa-solid fa-wand-magic-sparkles"></i> Activité IA
      </a>
      <span class="nav-section-label" style="margin-top:8px;">Outils</span>
      <a href="/notifications" class="nav-item <%= page === 'notifications' ? 'active' : '' %>">
        <i class="fa-solid fa-bell"></i> Notifications
      </a>
      <a href="/feedbacks" class="nav-item <%= page === 'feedbacks' ? 'active' : '' %>">
        <i class="fa-solid fa-comment-dots"></i> Feedbacks bêta
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/logout" class="btn-logout">
        <i class="fa-solid fa-right-from-bracket"></i> Déconnexion
      </a>
    </div>
  </aside>

  <main class="main">
    <div class="topbar">
      <div class="topbar-left">
        <button class="hamburger" id="hamburger" onclick="toggleSidebar()" aria-label="Menu">
          <i class="fa-solid fa-bars"></i>
        </button>
        <div class="topbar-title"><%= title || 'Trainwise Admin' %></div>
      </div>
      <div class="topbar-meta">Trainwise Admin</div>
    </div>
    <div class="content">
