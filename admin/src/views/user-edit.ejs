<%- include('_header', { title: (user.firstName || '') + ' ' + (user.lastName || user.email), page: 'users' }) %>

<a href="/users" class="back-link">← Retour aux utilisateurs</a>

<% if (success) { %>
  <div class="alert alert-success">✓ Utilisateur mis à jour avec succès</div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error">⚠️ <%= error %></div>
<% } %>

<!-- Header profil -->
<div class="user-profile-header">
  <div class="user-avatar-lg">
    <% if (user.profilePicture) { %>
      <img src="<%= user.profilePicture %>" alt="">
    <% } else { %>
      <%= (user.firstName || user.email || '?')[0].toUpperCase() %>
    <% } %>
  </div>
  <div class="user-profile-info">
    <h2>
      <%= user.firstName || '' %> <%= user.lastName || '' %>
      <% if (!user.firstName && !user.lastName) { %><span style="color:#94a3b8;font-weight:400;">Sans nom</span><% } %>
    </h2>
    <p>
      <%= user.email %>
      &nbsp;·&nbsp;
      <span class="badge badge-<%= user.role %>"><%= user.role %></span>
      &nbsp;
      <span class="badge badge-<%= user.subscriptionStatus %>"><%= user.subscriptionStatus === 'pro' ? '✦ Pro' : 'Free' %></span>
    </p>
    <p style="margin-top:4px;">
      Inscrit le <%= new Date(user.createdAt).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' }) %>
      <% if (user.phone) { %>&nbsp;·&nbsp;<%= user.phone %><% } %>
    </p>
  </div>
</div>

<!-- Mini stats -->
<div class="user-mini-stats">
  <div class="mini-stat">
    <div class="value"><%= runCount %></div>
    <div class="label">Sorties</div>
  </div>
  <div class="mini-stat">
    <div class="value"><%= totalKm %> km</div>
    <div class="label">Distance totale</div>
  </div>
  <div class="mini-stat">
    <div class="value"><%= avgFeeling %><%= avgFeeling !== '-' ? '/10' : '' %></div>
    <div class="label">Ressenti moyen</div>
  </div>
</div>

<div class="two-cols">
  <!-- Formulaire d'édition -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">Modifier les accès</span>
    </div>
    <div class="card-body">
      <form method="POST" action="/users/<%= user._id %>">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Rôle</label>
            <select name="role" class="form-control">
              <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>Utilisateur</option>
              <option value="coach" <%= user.role === 'coach' ? 'selected' : '' %>>Coach</option>
              <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Abonnement</label>
            <select name="subscriptionStatus" class="form-control">
              <option value="free" <%= user.subscriptionStatus === 'free' ? 'selected' : '' %>>Free</option>
              <option value="pro" <%= user.subscriptionStatus === 'pro' ? 'selected' : '' %>>Pro</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">TrainCoins</label>
            <input type="number" name="trainCoins" class="form-control" value="<%= user.trainCoins || 0 %>" min="0" step="0.5">
          </div>
          <div class="form-group">
            <label class="form-label">Expiration Pro</label>
            <input type="date" name="subscriptionExpiry" class="form-control"
              value="<%= user.subscriptionExpiry ? new Date(user.subscriptionExpiry).toISOString().split('T')[0] : '' %>">
          </div>
        </div>
        <div style="margin-top:20px;display:flex;justify-content:flex-end;">
          <button type="submit" class="btn btn-save">Enregistrer</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Infos profil (readonly) -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">Profil coureur</span>
    </div>
    <div class="card-body">
      <% const profileFields = [
        { label: 'Niveau', value: user.runningLevel },
        { label: 'Objectif', value: user.goal },
        { label: 'Âge', value: user.age },
        { label: 'Genre', value: user.gender },
        { label: 'Fréquence semaine', value: user.weeklyFrequency ? user.weeklyFrequency + 'x / sem.' : null },
        { label: 'VMA', value: user.vma ? user.vma + ' km/h' : null },
        { label: 'FC max', value: user.fcmax ? user.fcmax + ' bpm' : null },
        { label: 'Strava', value: user.strava && user.strava.athleteId ? 'Connecté (#' + user.strava.athleteId + ')' : 'Non connecté' },
        { label: 'Onboarding', value: user.hasCompletedOnboarding ? 'Complété' : 'Non complété' },
        { label: 'Push token', value: user.pushToken ? user.pushPlatform + ' — ' + user.pushToken.substring(0, 16) + '...' : null }
      ]; %>
      <% profileFields.forEach(f => { %>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(0,53,84,0.06);">
          <span style="font-size:0.8rem;color:#64748b;"><%= f.label %></span>
          <span style="font-size:0.82rem;font-weight:500;color:#003554;"><%= f.value || '—' %></span>
        </div>
      <% }); %>
    </div>
  </div>
</div>

<%- include('_footer') %>
