<%- include('_header', { title: (user.firstName || user.email || 'Utilisateur'), page: 'users' }) %>

<a href="/users" class="back-link">
  <i class="fa-solid fa-arrow-left"></i> Retour aux utilisateurs
</a>

<% if (success) { %>
  <div class="alert alert-success">
    <i class="fa-solid fa-circle-check"></i> Modifications enregistrées avec succès.
  </div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error">
    <i class="fa-solid fa-triangle-exclamation"></i> <%= error %>
  </div>
<% } %>

<!-- Profile header -->
<div class="profile-header">
  <div class="user-avatar-lg">
    <% if (user.profilePicture) { %>
      <img src="<%= user.profilePicture %>" alt="">
    <% } else { %>
      <%= (user.firstName || user.email || '?')[0].toUpperCase() %>
    <% } %>
  </div>
  <div class="profile-info">
    <h2>
      <%= user.firstName || '' %> <%= user.lastName || '' %>
      <% if (!user.firstName && !user.lastName) { %><span style="color:#94a3b8;font-weight:400;">Sans nom</span><% } %>
    </h2>
    <p>
      <i class="fa-solid fa-envelope" style="font-size:0.72rem;"></i> <%= user.email %>
      <span class="badge badge-<%= user.role %>"><%= user.role %></span>
      <span class="badge badge-<%= user.subscriptionStatus %>"><%= user.subscriptionStatus === 'pro' ? '✦ Pro' : 'Free' %></span>
    </p>
    <div class="profile-meta">
      <span><i class="fa-solid fa-calendar"></i> Inscrit le <%= new Date(user.createdAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'long', year:'numeric' }) %></span>
      <% if (user.phone) { %><span><i class="fa-solid fa-phone"></i> <%= user.phone %></span><% } %>
      <% if (user.strava && user.strava.athleteId) { %><span style="color:#fc4c02;"><i class="fa-solid fa-circle-dot"></i> Strava connecté</span><% } %>
    </div>
  </div>
</div>

<!-- Mini stats -->
<div class="user-mini-stats">
  <div class="mini-stat">
    <div class="mini-stat-icon stat-icon blue"><i class="fa-solid fa-route"></i></div>
    <div class="mini-stat-content">
      <div class="value"><%= runCount %></div>
      <div class="label">Sorties</div>
    </div>
  </div>
  <div class="mini-stat">
    <div class="mini-stat-icon stat-icon navy"><i class="fa-solid fa-ruler"></i></div>
    <div class="mini-stat-content">
      <div class="value"><%= totalKm %> km</div>
      <div class="label">Total</div>
    </div>
  </div>
  <div class="mini-stat">
    <div class="mini-stat-icon stat-icon orange"><i class="fa-solid fa-heart-pulse"></i></div>
    <div class="mini-stat-content">
      <div class="value"><%= avgFeeling %><%= avgFeeling !== '-' ? '/10' : '' %></div>
      <div class="label">Ressenti moy.</div>
    </div>
  </div>
</div>

<div class="two-cols">
  <!-- Édition -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fa-solid fa-pen-to-square" style="color:var(--blue);margin-right:6px;"></i>Modifier les accès</span>
    </div>
    <div class="card-body">
      <form method="POST" action="/users/<%= user._id %>">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Rôle</label>
            <select name="role" class="form-control">
              <option value="user"  <%= user.role === 'user'  ? 'selected' : '' %>>Utilisateur</option>
              <option value="coach" <%= user.role === 'coach' ? 'selected' : '' %>>Coach</option>
              <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Abonnement</label>
            <select name="subscriptionStatus" class="form-control">
              <option value="free" <%= user.subscriptionStatus === 'free' ? 'selected' : '' %>>Free</option>
              <option value="pro"  <%= user.subscriptionStatus === 'pro'  ? 'selected' : '' %>>Pro</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">TrainCoins</label>
            <input type="number" name="trainCoins" class="form-control" value="<%= user.trainCoins || 0 %>" min="0" step="0.5">
          </div>
          <div class="form-group">
            <label class="form-label">Expiration Pro</label>
            <input type="date" name="subscriptionExpiry" class="form-control"
              value="<%= user.subscriptionExpiry ? new Date(user.subscriptionExpiry).toISOString().split('T')[0] : '' %>">
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-save"><i class="fa-solid fa-floppy-disk"></i> Enregistrer</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Profil readonly -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fa-solid fa-id-card" style="color:var(--text-muted);margin-right:6px;"></i>Profil coureur</span>
    </div>
    <div class="card-body">
      <div class="field-list">
        <% const fields = [
          { icon: 'fa-gauge-high',    label: 'Niveau',         value: user.runningLevel },
          { icon: 'fa-bullseye',      label: 'Objectif',       value: user.goal },
          { icon: 'fa-cake-candles',  label: 'Âge',            value: user.age },
          { icon: 'fa-venus-mars',    label: 'Genre',          value: user.gender },
          { icon: 'fa-calendar-days', label: 'Fréquence',      value: user.weeklyFrequency ? user.weeklyFrequency + 'x / sem.' : null },
          { icon: 'fa-bolt',          label: 'VMA',            value: user.vma ? user.vma + ' km/h' : null },
          { icon: 'fa-heart',         label: 'FC max',         value: user.fcmax ? user.fcmax + ' bpm' : null },
          { icon: 'fa-circle-check',  label: 'Onboarding',     value: user.hasCompletedOnboarding ? 'Complété' : 'Non complété' },
          { icon: 'fa-bell',          label: 'Push',           value: user.pushToken ? (user.pushPlatform + ' · ' + user.pushToken.substring(0,12) + '…') : null }
        ]; %>
        <% fields.forEach(f => { %>
        <div class="field-row">
          <span class="field-label"><i class="fa-solid <%= f.icon %>"></i><%= f.label %></span>
          <span class="field-value"><%= f.value || '—' %></span>
        </div>
        <% }); %>
      </div>
    </div>
  </div>
</div>

<%- include('_footer') %>
