<%- include('_header', { title: 'Dashboard', page: 'dashboard' }) %>

<div class="page-header">
  <h1>Dashboard</h1>
  <p>Vue d'ensemble de la plateforme Trainwise</p>
</div>

<!-- Stat cards -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-card-top">
      <div class="stat-label">Utilisateurs</div>
      <div class="stat-icon navy"><i class="fa-solid fa-users"></i></div>
    </div>
    <div class="stat-value"><%= stats.totalUsers %></div>
    <div class="stat-sub">+<%= stats.newUsersThisWeek %> cette semaine</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-top">
      <div class="stat-label">Abonnés Pro</div>
      <div class="stat-icon green"><i class="fa-solid fa-star"></i></div>
    </div>
    <div class="stat-value"><%= stats.proUsers %></div>
    <div class="stat-sub"><%= stats.conversionRate %>% de conversion</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-top">
      <div class="stat-label">Coaches</div>
      <div class="stat-icon purple"><i class="fa-solid fa-person-running"></i></div>
    </div>
    <div class="stat-value"><%= stats.coaches %></div>
    <div class="stat-sub"><%= stats.athletes %> athlètes</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-top">
      <div class="stat-label">Nouveaux ce mois</div>
      <div class="stat-icon blue"><i class="fa-solid fa-user-plus"></i></div>
    </div>
    <div class="stat-value"><%= stats.newUsersThisMonth %></div>
    <div class="stat-sub">inscriptions</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-top">
      <div class="stat-label">Sorties</div>
      <div class="stat-icon orange"><i class="fa-solid fa-route"></i></div>
    </div>
    <div class="stat-value"><%= stats.totalRuns.toLocaleString('fr-FR') %></div>
    <div class="stat-sub"><%= stats.totalKm.toLocaleString('fr-FR') %> km au total</div>
  </div>
</div>

<div class="two-cols">
  <!-- Graphe inscriptions -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fa-solid fa-chart-bar" style="color:var(--blue);margin-right:6px;"></i>Inscriptions — 6 mois</span>
    </div>
    <div class="card-body">
      <div class="chart-container">
        <canvas id="chartUsers"></canvas>
      </div>
    </div>
  </div>

  <!-- Répartition -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fa-solid fa-chart-pie" style="color:var(--purple);margin-right:6px;"></i>Répartition</span>
    </div>
    <div class="card-body">
      <% const items = [
        { label: 'Utilisateurs free', value: stats.totalUsers - stats.proUsers - stats.coaches, color: '#94a3b8' },
        { label: 'Abonnés Pro',       value: stats.proUsers,  color: '#10b981' },
        { label: 'Coaches',           value: stats.coaches,   color: '#8b5cf6' }
      ]; %>
      <% items.forEach(item => { %>
        <div class="progress-row">
          <div class="progress-meta">
            <span class="progress-label"><%= item.label %></span>
            <span class="progress-val"><%= item.value %></span>
          </div>
          <div class="progress-track">
            <div class="progress-fill" style="background:<%= item.color %>;width:<%= stats.totalUsers > 0 ? Math.round((item.value/stats.totalUsers)*100) : 0 %>%;"></div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</div>

<!-- Derniers inscrits -->
<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="fa-solid fa-clock-rotate-left" style="color:var(--text-muted);margin-right:6px;"></i>Derniers inscrits</span>
    <a href="/users" class="btn btn-secondary"><i class="fa-solid fa-arrow-right"></i> Voir tous</a>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Utilisateur</th>
          <th>Rôle</th>
          <th>Abonnement</th>
          <th>Inscrit le</th>
        </tr>
      </thead>
      <tbody>
        <% recentUsers.forEach(u => { %>
        <tr>
          <td>
            <a href="/users/<%= u._id %>" class="table-link" style="display:flex;align-items:center;gap:10px;">
              <div style="width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,#00a6fb,#0582ca);display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.78rem;font-weight:700;flex-shrink:0;overflow:hidden;">
                <% if (u.profilePicture) { %>
                  <img src="<%= u.profilePicture %>" style="width:100%;height:100%;object-fit:cover;" alt="">
                <% } else { %>
                  <%= (u.firstName || u.email || '?')[0].toUpperCase() %>
                <% } %>
              </div>
              <div>
                <div style="font-weight:500;font-size:0.84rem;">
                  <%= u.firstName || '' %> <%= u.lastName || '' %>
                  <% if (!u.firstName && !u.lastName) { %><span class="text-muted">Sans nom</span><% } %>
                </div>
                <div class="text-small text-muted"><%= u.email %></div>
              </div>
            </a>
          </td>
          <td><span class="badge badge-<%= u.role %>"><%= u.role %></span></td>
          <td><span class="badge badge-<%= u.subscriptionStatus %>"><%= u.subscriptionStatus === 'pro' ? '✦ Pro' : 'Free' %></span></td>
          <td class="text-muted text-small"><%= new Date(u.createdAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', year:'numeric' }) %></td>
        </tr>
        <% }); %>
        <% if (!recentUsers.length) { %>
        <tr><td colspan="4"><div class="empty-state"><i class="fa-solid fa-inbox"></i><p>Aucun utilisateur</p></div></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  const ctx = document.getElementById('chartUsers').getContext('2d');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: <%- JSON.stringify(monthlyLabels) %>,
      datasets: [{
        label: 'Inscriptions',
        data: <%- JSON.stringify(monthlyCounts) %>,
        backgroundColor: 'rgba(0, 166, 251, 0.15)',
        borderColor: '#00a6fb',
        borderWidth: 2,
        borderRadius: 6,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { font: { family: 'Inter', size: 11 }, color: '#94a3b8' } },
        y: { grid: { color: '#f1f5f9' }, ticks: { font: { family: 'Inter', size: 11 }, color: '#94a3b8', precision: 0 }, beginAtZero: true }
      }
    }
  });
</script>

<%- include('_footer') %>
