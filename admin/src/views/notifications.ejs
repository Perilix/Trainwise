<%- include('_header', { title: 'Notifications', page: 'notifications' }) %>

<div class="page-header">
  <h1>Notifications Push</h1>
  <p>Broadcast vers vos utilisateurs iOS &amp; Android</p>
</div>

<div class="two-cols">

  <!-- Formulaire -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fa-solid fa-paper-plane" style="color:var(--blue);margin-right:6px;"></i>Nouvelle notification</span>
    </div>
    <div class="card-body">

      <% if (success) { %>
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> <%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><i class="fa-solid fa-triangle-exclamation"></i> <%= error %></div>
      <% } %>

      <form method="POST" action="/notifications">
        <div class="form-group">
          <label class="form-label">Titre</label>
          <input type="text" name="title" class="form-input" placeholder="Ex: Nouvelle fonctionnalité !" required maxlength="100">
        </div>
        <div class="form-group">
          <label class="form-label">Message</label>
          <textarea name="body" class="form-input" rows="4" placeholder="Votre message…" required maxlength="300" style="resize:vertical;"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Destinataires</label>
          <select name="segment" class="form-input">
            <option value="all">Tous — <strong><%= stats.withToken %></strong> appareils enregistrés</option>
            <option value="pro">Abonnés Pro uniquement</option>
            <option value="free">Utilisateurs Free uniquement</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:4px;">
          <i class="fa-solid fa-paper-plane"></i> Envoyer
        </button>
      </form>
    </div>
  </div>

  <!-- Stats + infos -->
  <div style="display:flex;flex-direction:column;gap:16px;">
    <div class="stats-grid" style="grid-template-columns:1fr 1fr;">
      <div class="stat-card">
        <div class="stat-card-top">
          <div class="stat-label">Appareils actifs</div>
          <div class="stat-icon blue"><i class="fa-solid fa-mobile-screen"></i></div>
        </div>
        <div class="stat-value"><%= stats.withToken %></div>
        <div class="stat-sub">tokens valides</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-top">
          <div class="stat-label">Envois totaux</div>
          <div class="stat-icon navy"><i class="fa-solid fa-bell"></i></div>
        </div>
        <div class="stat-value"><%= logs.reduce((s, l) => s + l.sent, 0).toLocaleString('fr-FR') %></div>
        <div class="stat-sub"><%= logs.length %> campagne<%= logs.length > 1 ? 's' : '' %></div>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <p style="font-size:0.82rem;color:var(--text-muted);margin:0 0 10px;font-weight:600;"><i class="fa-solid fa-circle-info" style="margin-right:6px;color:var(--blue);"></i>Notes</p>
        <ul style="font-size:0.8rem;color:var(--text-muted);padding-left:16px;margin:0;line-height:2;">
          <li>Nécessite <code>FIREBASE_SERVICE_ACCOUNT</code> en variable d'env</li>
          <li>Tokens invalides (UNREGISTERED) sont nettoyés automatiquement</li>
          <li>iOS et Android supportés via FCM</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<!-- Historique -->
<div class="card" style="margin-top:24px;">
  <div class="card-header">
    <span class="card-title"><i class="fa-solid fa-clock-rotate-left" style="color:var(--text-muted);margin-right:6px;"></i>Historique des envois</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Titre</th>
          <th>Message</th>
          <th>Segment</th>
          <th>Envoyés</th>
          <th>Échecs</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <% logs.forEach(log => { %>
        <tr>
          <td style="font-weight:600;font-size:0.85rem;max-width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= log.title %></td>
          <td style="font-size:0.8rem;color:var(--text-muted);max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= log.body %></td>
          <td>
            <span class="badge" style="background:<%= log.segment === 'pro' ? 'rgba(16,185,129,0.1)' : log.segment === 'free' ? 'rgba(0,166,251,0.1)' : 'rgba(0,53,84,0.08)' %>;color:<%= log.segment === 'pro' ? '#059669' : log.segment === 'free' ? '#0582ca' : 'var(--navy)' %>;">
              <%= log.segment === 'pro' ? '✦ Pro' : log.segment === 'free' ? 'Free' : 'Tous' %>
            </span>
          </td>
          <td style="font-weight:700;color:var(--success);"><i class="fa-solid fa-circle-check" style="font-size:0.7rem;margin-right:4px;"></i><%= log.sent %></td>
          <td>
            <% if (log.failed > 0) { %>
              <span style="color:#ef4444;font-weight:600;"><%= log.failed %></span>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td class="text-muted text-small"><%= new Date(log.sentAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', year:'numeric' }) %> <span style="color:#cbd5e1;margin:0 2px;">·</span> <%= new Date(log.sentAt).toLocaleTimeString('fr-FR', { hour:'2-digit', minute:'2-digit' }) %></td>
        </tr>
        <% }); %>
        <% if (!logs.length) { %>
        <tr>
          <td colspan="6">
            <div class="empty-state">
              <i class="fa-solid fa-bell-slash"></i>
              <p>Aucune notification envoyée pour l'instant</p>
            </div>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('_footer') %>
