PORT=3000
NODE_ENV=production

# MongoDB — utiliser MongoDB Atlas en prod (connection string depuis Atlas > Connect)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/runiq?retryWrites=true&w=majority

# JWT — générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_EXPIRE=7d

# URLs
BACKEND_URL=https://trainwise-backend-rnd4.onrender.com
FRONTEND_URL=https://TON_DOMAINE_OU_RENDER_URL

# Email (Nodemailer + Gmail)
EMAIL_USER=app.trainwise@gmail.com
EMAIL_PASSWORD=GMAIL_APP_PASSWORD_ICI

# Strava OAuth (depuis https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=STRAVA_CLIENT_ID
STRAVA_CLIENT_SECRET=STRAVA_CLIENT_SECRET

# Cloudinary (depuis https://cloudinary.com/console)
CLOUDINARY_KEY=CLOUDINARY_KEY
CLOUDINARY_SECRET=CLOUDINARY_SECRET
CLOUDINARY_NAME=CLOUDINARY_NAME
CLOUDINARY_URL=cloudinary://KEY:SECRET@NAME

# AdminJS — changer absolument avant le lancement
ADMIN_EMAIL=admin@runiq.fr
ADMIN_PASSWORD=MOT_DE_PASSE_FORT_ICI

# N8N Webhooks
N8N_WEBHOOK_URL=https://TON_N8N.app.n8n.cloud/webhook/runiq-analyze
N8N_PLANNING_WEBHOOK_URL=https://TON_N8N.app.n8n.cloud/webhook/runiq-planning

# Firebase Admin SDK — coller le JSON complet depuis Firebase Console > Project Settings > Service accounts
FIREBASE_SERVICE_ACCOUNT='{...json complet...}'
